# Copy to .env.local for local dev, or set these in the Netlify dashboard.

# Base URL of the Python API (no trailing slash).
VITE_API_BASE_URL=http://localhost:8000

# When "true", the dashboard never calls the API and serves precomputed
# responses from src/demoData.ts. Use this for the static Netlify demo or when
# the backend is unavailable.
VITE_DEMO_MODE=false
