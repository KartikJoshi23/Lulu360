# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- Trained model artifacts (large; regenerated by train_reader.py) ---
# Ignore stray weights anywhere, BUT track the Reader's shipped artifacts so the
# deployed backend (and a fresh clone) runs the real LSTM, not the keyword
# fallback. ~5.5 MB total — small enough for git, large enough to matter.
*.keras
*.h5
backend/models/*.keras
backend/models/*.h5
backend/models/*.json
!backend/models/reader_issue.keras
!backend/models/reader_frustration.keras
!backend/models/tokenizer.json
!backend/models/label_maps.json

# --- Runtime logs / audit output ---
backend/logs/*.jsonl

# --- Node / frontend ---
node_modules/
dist/
build/
.env
.env.local
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/
*.log
.ipynb_checkpoints/

# --- Claude Code local settings ---
.claude/settings.local.json
